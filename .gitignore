# Include your project-specific ignores in this file
# Read about how to use .gitignore: https://help.github.com/articles/ignoring-files
# Useful .gitignore templates: https://github.com/github/gitignore
node_modules
dist
.cache

# Generated CSS (rebuilt by `npm run tokens`)
css/tokens.css
css/tokens-mobile.css
css/tokens-dark.css
css/tokens-minimised.css
css/tokens-chat.css
css/tokens-chat-dark.css

# IDE
.idea

# Local workspace — reference screenshots and scratch scripts
refs/
tmp/

# Docs site — generated content (rebuilt by `npm run docs:generate`)
docs-site/components/
docs-site/patterns/
docs-site/templates/
docs-site/.vitepress/sidebar-data.json
docs-site/.vitepress/dist/
docs-site/.vitepress/cache/
docs-site/public/demos/
docs-site/node_modules

# Claude Code local settings — machine-specific files are ignored,
# but .claude/commands/ (shared slash-command skills) is tracked.
.claude/*
!.claude/commands/
!.claude/commands/**
!.claude/memory/
!.claude/memory/**

# Credentials — never commit tokens or API keys
.env
FigmaTokens/*.md
*.token
*.secret